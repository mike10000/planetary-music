# Gmail credentials for sending form emails
# Create an App Password at: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Optional: Override recipient (default: info@miketintnerproductions.com)
# To add multiple recipients, use comma-separated: email1@example.com,email2@example.com
# FORM_RECIPIENT_EMAIL=info@miketintnerproductions.com
